{
	frankenphp
	order php_server before file_server
	# Railway termine le TLS en amont : pas de HTTPS auto dans le conteneur
	auto_https off
}

# Ecoute sur le port fourni par Railway ($PORT), 8080 par defaut en local
:{$PORT:8080} {
	root * /app/public
	encode zstd gzip

	route {
		# Bloque l'acces direct au dossier vendor/
		@vendor path /vendor/*
		respond @vendor 403

		# Bloque les fichiers sensibles (logs, dumps, backups, fichiers projet)
		@sensitive path *.log *.sql *.bak /composer.json /composer.lock /composer.phar /README.md /CHANGELOG.md /mode_emploi_admin.txt /INSTALL_PHPMailer.txt /mon_horaire_test.php /evaluation_temp.json
		respond @sensitive 403

		# Bloque les fichiers de test (test*.php / test*.xlsx)
		@testfiles path_regexp testfiles ^/test[^/]*\.(php|xlsx)$
		respond @testfiles 403

		# Bloque l'acces direct aux scores du quiz (/quiz/data/scores.json contient
		# les prenoms des participants ; seul api.php doit les lire)
		@quizdata path /quiz/data/*
		respond @quizdata 403

		# Le quiz est un site STATIQUE : son index est index.html. Or php_server ne
		# reconnait que index.php comme index de dossier : /quiz/ ne trouvait donc
		# rien et retombait sur le index.php de l'app principale, qui redirige vers
		# la connexion -> boucle de redirection. On sert explicitement index.html.
		@quizIndex path /quiz /quiz/
		rewrite @quizIndex /quiz/index.html

		# Meme chose pour la page d'administration. Le / final est impose d'abord :
		# la page appelle "../api.php", qui ne pointe au bon endroit que depuis
		# /quiz/admin/ (depuis /quiz/admin, ".." remonterait a la racine du site).
		redir /quiz/admin /quiz/admin/ 308
		@quizAdmin path /quiz/admin/
		rewrite @quizAdmin /quiz/admin/index.html

		# Ecrans dedies : /quiz/tele (affichage TV), /quiz/borne (borne) et
		# /quiz/code (recuperation d'un code bonus). Ils servent la MEME page que
		# /quiz ; c'est la page qui detecte le mode selon l'URL. On garde la forme
		# SANS slash final pour que le relatif "api.php" reste a la racine /quiz/.
		redir /quiz/tele/ /quiz/tele 308
		redir /quiz/borne/ /quiz/borne 308
		redir /quiz/code/ /quiz/code 308
		@quizEcrans path /quiz/tele /quiz/borne /quiz/code
		rewrite @quizEcrans /quiz/index.html

		# Bloque les fichiers caches (.env, .htaccess, .gitignore, ...)
		@dotfiles path_regexp dotfiles /\.[^/]+$
		respond @dotfiles 403

		php_server
	}
}
